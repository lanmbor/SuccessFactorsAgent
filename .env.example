# ── SuccessFactors ───────────────────────────────────
SF_BASE_URL=https://api4.successfactors.com
SF_COMPANY_ID=your_company_id
SF_USER_ID=admin_user_id
SF_CLIENT_ID=your_api_key_from_sf_provisioning
SF_PRIVATE_KEY_PATH=./certs/private_key.pem

# ── LLM Provider ─────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-...
LLM_API_BASE=

# ── Telegram (optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ── WhatsApp via Meta Cloud API (optional) ────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ── WhatsApp via Twilio sandbox (optional) ────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
